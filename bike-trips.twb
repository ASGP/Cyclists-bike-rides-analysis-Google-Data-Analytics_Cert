      <aliases enabled='yes' />
      <column caption='member count' datatype='integer' name='[Calculation_0755103123234816]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [member_casual] = &quot;member&quot; THEN [ride_id] END)' />
      </column>
      <column caption='Member %' datatype='real' name='[Calculation_0755103123951617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [member_casual] = &quot;member&quot; THEN [ride_id] END) /&#13;&#10;COUNTD([ride_id]) * 100' />
      </column>
      <column caption='casual rides' datatype='integer' name='[Calculation_0755103124656130]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [member_casual] = &quot;casual&quot; THEN [ride_id] END)' />
      </column>
      <column caption='casual %' datatype='real' name='[Calculation_0755103125176323]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [member_casual] = &quot;casual&quot; THEN [ride_id] END) /&#13;&#10;COUNTD([ride_id]) * 100' />
      </column>
      <column caption='eletric count' datatype='integer' name='[Calculation_0755103126503428]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [rideable_type] = &quot;electric_bike&quot; THEN [ride_id] END)' />
      </column>
      <column caption='elevtric %' datatype='real' name='[Calculation_0755103126585349]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [rideable_type] = &quot;electric_bike&quot; THEN [ride_id] END) /&#13;&#10;COUNTD([ride_id]) * 100' />
      </column>
      <column caption='classis count' datatype='integer' name='[Calculation_0755103126896646]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [rideable_type] = &quot;classic_bike&quot; THEN [ride_id] END)' />
      </column>
      <column caption='classic %' datatype='real' name='[Calculation_0755103127052295]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [rideable_type] = &quot;classic_bike&quot; THEN [ride_id] END) /&#13;&#10;COUNTD([ride_id]) * 100' />
      </column>
      <column caption='avg rides in minutes' datatype='real' name='[Calculation_1232840168476672]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([ride_length_seconds]) / 60' />
      </column>
      <column caption='Commute Period' datatype='string' name='[Calculation_1232840222527489]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [hour] &gt;= 6 AND [hour] &lt;= 9 THEN &quot;Morning Commute&quot;&#13;&#10;ELSEIF [hour] &gt;= 16 AND [hour] &lt;= 19 THEN &quot;Evening Commute&quot;&#13;&#10;ELSE &quot;Off Peak&quot;&#13;&#10;END' />
        <aliases>
          <alias key='&quot;Evening Commute&quot;' value='Evening ' />
          <alias key='&quot;Morning Commute&quot;' value='Morning' />
        </aliases>
      </column>
      <column caption='Ride Duration (Minutes)' datatype='real' name='[Calculation_1232840227553282]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[ride_length_seconds] / 60' />
      </column>
      <column caption='Day Type' datatype='string' name='[Calculation_1232840248561667]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [day_of_week] = &quot;Saturday&quot; OR [day_of_week] = &quot;Sunday&quot; &#13;&#10;THEN &quot;Weekend&quot; &#13;&#10;ELSE &quot;Weekday&quot; &#13;&#10;END' />
      </column>
      <column aggregation='None' caption='Ride Duration (Minutes) (bin) 2' datatype='integer' name='[Ride Duration (Minutes) (bin) 2]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[Calculation_1232840227553282]' peg='0' size='5' />
      </column>
      <column aggregation='None' datatype='integer' name='[Ride Duration (Minutes) (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='0' formula='[Calculation_1232840227553282]' peg='0' size='2' />
      </column>
